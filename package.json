    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-angular": "^1.0.0",
